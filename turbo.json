{
	"$schema": "https://turborepo.org/schema.json",
	"ui": "stream",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"@bedrock/website#build": {
			"outputs": [".vitepress/dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build", "@bedrock/vitest-config#build"],
			"outputs": ["coverage/**"]
		},
		"test:watch": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"typecheck": {
			"dependsOn": ["^build"]
		}
	}
}
