{
	"name": "@bedrock-rbx/core",
	"version": "0.1.0-beta.7",
	"description": "Infrastructure-as-Code deployment tool for Roblox",
	"keywords": [
		"infrastructure",
		"roblox",
		"deployment",
		"cli"
	],
	"homepage": "https://bedrock-livid.vercel.app/",
	"bugs": {
		"url": "https://github.com/christopher-buss/bedrock/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christopher-buss/bedrock.git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"sideEffects": false,
	"type": "module",
	"imports": {
		"#src/*": "./src/*.ts",
		"#tests/*": "./tests/*.ts"
	},
	"exports": {
		".": {
			"source": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./cli/run": {
			"source": "./src/cli/run.ts",
			"default": "./dist/cli/run.mjs"
		},
		"./config": {
			"source": "./src/config.ts",
			"default": "./dist/config.mjs"
		},
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.mts",
	"bin": {
		"bedrock": "./dist/cli/run.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"test": "vp test",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@bedrock-rbx/ocale": "workspace:*",
		"@clack/prompts": "catalog:runtime",
		"arktype": "catalog:runtime",
		"c12": "catalog:runtime",
		"confbox": "catalog:runtime",
		"defu": "catalog:runtime",
		"sade": "catalog:runtime"
	},
	"devDependencies": {
		"@bedrock-rbx/testing": "workspace:*",
		"@bedrock-rbx/typescript-config": "workspace:*",
		"@bedrock-rbx/vite-config": "workspace:*",
		"@stryker-mutator/api": "catalog:test",
		"@stryker-mutator/core": "catalog:test",
		"@stryker-mutator/typescript-checker": "catalog:test",
		"@stryker-mutator/vitest-runner": "catalog:test",
		"@types/bun": "catalog:types",
		"oxc-minify": "catalog:dev",
		"type-fest": "catalog:types",
		"typescript": "catalog:tsc",
		"vitest": "catalog:test"
	},
	"engines": {
		"node": ">=24.12.0",
		"bun": ">=1.3.0"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": "./dist/index.mjs",
			"./cli/run": "./dist/cli/run.mjs",
			"./config": "./dist/config.mjs",
			"./package.json": "./package.json"
		}
	},
	"inlinedDependencies": {
		"tagged-tag": "1.0.0",
		"type-fest": "5.6.0"
	}
}
