{
	"name": "@bedrock/ocale",
	"version": "0.0.1",
	"description": "Roblox Open Cloud API client",
	"keywords": [
		"api",
		"ocale",
		"open-cloud",
		"roblox"
	],
	"homepage": "https://bedrock-livid.vercel.app/",
	"bugs": {
		"url": "https://github.com/christopher-buss/bedrock/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christopher-buss/bedrock/tree/main/packages/open-cloud.git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"sideEffects": false,
	"type": "module",
	"imports": {
		"#src/*": "./src/*.ts",
		"#tests/*": "./tests/*.ts"
	},
	"exports": {
		".": {
			"source": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./developer-products": {
			"source": "./src/resources/developer-products/index.ts",
			"default": "./dist/developer-products.mjs"
		},
		"./experience-icon": {
			"source": "./src/resources/experience-icon/index.ts",
			"default": "./dist/experience-icon.mjs"
		},
		"./experience-thumbnails": {
			"source": "./src/resources/experience-thumbnails/index.ts",
			"default": "./dist/experience-thumbnails.mjs"
		},
		"./game-passes": {
			"source": "./src/resources/game-passes/index.ts",
			"default": "./dist/game-passes.mjs"
		},
		"./package.json": "./package.json",
		"./places": {
			"source": "./src/resources/places/index.ts",
			"default": "./dist/places.mjs"
		},
		"./testing": {
			"default": "./tests/helpers/index.ts",
			"source": "./tests/helpers/index.ts"
		},
		"./universes": {
			"source": "./src/resources/universes/index.ts",
			"default": "./dist/universes.mjs"
		}
	},
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"refresh-openapi": "bun scripts/fetch-openapi.ts",
		"test": "vp test",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@bedrock/testing": "workspace:*",
		"@bedrock/typescript-config": "workspace:*",
		"@bedrock/vite-config": "workspace:*",
		"@stryker-mutator/api": "catalog:test",
		"@stryker-mutator/core": "catalog:test",
		"@stryker-mutator/typescript-checker": "catalog:test",
		"@stryker-mutator/vitest-runner": "catalog:test",
		"@types/bun": "catalog:types",
		"ajv": "catalog:test",
		"ajv-formats": "catalog:test",
		"oxc-minify": "catalog:dev",
		"type-fest": "catalog:types",
		"typescript": "catalog:tsc",
		"vitest": "catalog:test"
	},
	"engines": {
		"node": ">=24.12.0",
		"bun": ">=1.3.0"
	},
	"publishConfig": {
		"exports": {
			".": "./dist/index.mjs",
			"./developer-products": "./dist/developer-products.mjs",
			"./experience-icon": "./dist/experience-icon.mjs",
			"./experience-thumbnails": "./dist/experience-thumbnails.mjs",
			"./game-passes": "./dist/game-passes.mjs",
			"./package.json": "./package.json",
			"./places": "./dist/places.mjs",
			"./universes": "./dist/universes.mjs"
		}
	}
}
