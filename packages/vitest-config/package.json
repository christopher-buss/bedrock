{
	"name": "@bedrock/vitest-config",
	"version": "0.0.0",
	"private": true,
	"description": "Shared Vitest configuration for Bedrock packages",
	"keywords": ["vitest", "configuration", "testing"],
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc --watch",
		"lint": "eslint --cache src",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"vitest": "catalog:test"
	},
	"devDependencies": {
		"@bedrock/typescript-config": "workspace:*",
		"@types/bun": "catalog:types",
		"typescript": "catalog:tsc"
	},
	"engines": {
		"bun": ">=1.0.0"
	}
}
