{
	"name": "bedrock",
	"version": "0.0.1",
	"description": "Infrastructure-as-Code deployment tool for Roblox",
	"keywords": [
		"infrastructure",
		"roblox",
		"deployment",
		"cli"
	],
	"homepage": "https://bedrock-livid.vercel.app/",
	"bugs": {
		"url": "https://github.com/christopher-buss/bedrock/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christopher-buss/bedrock.git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"test": "vitest",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@bedrock/testing": "workspace:*",
		"@bedrock/typescript-config": "workspace:*",
		"@bedrock/vite-config": "workspace:*",
		"@types/bun": "catalog:types",
		"typescript": "catalog:tsc",
		"vitest": "catalog:test"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"publishConfig": {
		"exports": {
			".": "./dist/index.mjs",
			"./package.json": "./package.json"
		}
	}
}
