{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@isentinel/tsconfig/typescript",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "${configDir}/dist/.tsbuildinfo",
		"libReplacement": true,
		"customConditions": ["source"],
		"types": ["bun"],
		"declarationDir": "${configDir}/dist",
		"noEmit": false
	},
	"include": ["${configDir}/**/*"],
	"exclude": [
		"${configDir}/node_modules",
		"${configDir}/**/.*/",
		"${configDir}/dist",
		"${configDir}/coverage"
	]
}
