{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": false,
		"rootDir": "${configDir}/src",
		"declaration": true,
		"declarationMap": true,
		"outDir": "${configDir}/dist"
	},
	"include": ["${configDir}/src"],
	"exclude": ["${configDir}/src/**/*.spec.ts", "${configDir}/src/**/*.test.ts"]
}
