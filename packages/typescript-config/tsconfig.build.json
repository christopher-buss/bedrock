{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": false,
		"rootDir": "${configDir}/src",
		"declaration": true,
		"declarationDir": "${configDir}/dist",
		"declarationMap": true,
		"outDir": "${configDir}/dist"
	},
	"include": ["${configDir}/src"]
}
