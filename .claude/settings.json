{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true"
	},
	"includeCoAuthoredBy": true,
	"permissions": {
		"allow": [
			"Bash(gh:*)",
			"Bash(gh pr:*)",
			"Bash(gh pr create:*)",
			"Bash(gh pr view:*)",
			"Bash(gh run list:*)",
			"Bash(gh run view:*)",
			"Glob",
			"Grep",
			"LS",
			"Read",
			"Read(*)",
			"TodoWrite",
			"WebFetch",
			"WebSearch"
		],
		"deny": [],
		"defaultMode": "plan"
	},
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": "bun ${CLAUDE_PROJECT_DIR}/scripts/session-start-worktree-setup.ts",
						"timeout": 300
					}
				]
			}
		],
		"WorktreeCreate": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun ${CLAUDE_PROJECT_DIR}/scripts/worktree-create.ts",
						"timeout": 300
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"sentinel@isentinel": true,
		"typescript-lsp@claude-plugins-official": true,
		"worktrunk@worktrunk": true
	},
	"extraKnownMarketplaces": {
		"isentinel": {
			"source": {
				"source": "github",
				"repo": "christopher-buss/skills"
			},
			"autoUpdate": true
		},
		"worktrunk": {
			"source": {
				"source": "github",
				"repo": "max-sixty/worktrunk"
			}
		}
	},
	"outputStyle": "sentinel:XP Programmer"
}
