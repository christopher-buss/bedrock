{
	"name": "@bedrock/bedrock",
	"version": "0.0.0",
	"private": true,
	"description": "IaC for Roblox deployment",
	"keywords": ["infrastructure", "roblox", "deployment"],
	"homepage": "https://github.com/christopher-buss/bedrock#readme",
	"bugs": "https://github.com/christopher-buss/bedrock/issues",
	"repository": {
		"url": "git+https://github.com/christopher-buss/bedrock.git",
		"type": "git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"coverage:merge": "tsx scripts/merge-coverage.ts",
		"dev": "turbo dev",
		"gen:example-tests": "gen-jet packages/cli/src packages/open-cloud/src --header 'import { expect, it } from \"vitest\";' --test-file-extension '.example.spec' --test-function-name it",
		"lint": "eslint --cache .",
		"lint:ci": "eslint --cache --cache-strategy content .",
		"test": "vitest run",
		"test:ci": "turbo test -- --coverage && pnpm coverage:merge",
		"test:watch": "vitest --watch",
		"typecheck": "turbo typecheck"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix --cache"
	},
	"devDependencies": {
		"@antfu/ni": "catalog:dev",
		"@bedrock/typescript-config": "workspace:*",
		"@bedrock/vitest-config": "workspace:*",
		"@isentinel/eslint-config": "catalog:lint",
		"@isentinel/tsconfig": "catalog:tsc",
		"@types/bun": "catalog:types",
		"@typescript/native-preview": "catalog:types",
		"@vitest/coverage-v8": "catalog:test",
		"@vitest/eslint-plugin": "catalog:lint",
		"better-typescript-lib": "catalog:tsc",
		"eslint": "catalog:lint",
		"eslint-plugin-n": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"generate-jsdoc-example-tests": "catalog:",
		"jiti": "catalog:script",
		"lint-staged": "catalog:lint",
		"monocart-coverage-reports": "catalog:test",
		"pncat": "catalog:cli",
		"publint": "catalog:lint",
		"simple-git-hooks": "catalog:lint",
		"tsdown": "catalog:build",
		"tsx": "catalog:script",
		"turbo": "catalog:monorepo",
		"typescript": "catalog:tsc",
		"unplugin-unused": "catalog:build",
		"vitest": "catalog:test"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
	"engines": {
		"bun": ">=1.0.0"
	}
}
