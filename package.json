{
	"name": "@bedrock/bedrock",
	"version": "0.0.0",
	"private": true,
	"description": "IaC for Roblox deployment",
	"keywords": [
		"infrastructure",
		"roblox",
		"deployment"
	],
	"homepage": "https://github.com/christopher-buss/bedrock#readme",
	"bugs": "https://github.com/christopher-buss/bedrock/issues",
	"repository": {
		"url": "git+https://github.com/christopher-buss/bedrock.git",
		"type": "git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"scripts": {
		"build": "vp run -r build",
		"build:affected": "vp run -r build",
		"commit": "commit",
		"coverage:merge": "tsx scripts/merge-coverage.ts",
		"dev": "vp run -r dev",
		"gen:example-tests": "bun scripts/generate-example-tests.ts",
		"lint": "eslint --cache .",
		"lint:affected": "eslint --cache .",
		"test": "vp test",
		"test:affected": "vp test",
		"test:ci": "vp test --coverage && pnpm coverage:merge",
		"test:watch": "vp test --watch",
		"typecheck": "vp run -r typecheck",
		"typecheck:affected": "vp run -r typecheck"
	},
	"devDependencies": {
		"@bedrock/testing": "workspace:*",
		"@bedrock/typescript-config": "workspace:*",
		"@bedrock/vite-config": "workspace:*",
		"@commitlint/cli": "catalog:lint",
		"@commitlint/config-conventional": "catalog:lint",
		"@commitlint/config-pnpm-scopes": "catalog:lint",
		"@commitlint/prompt-cli": "catalog:lint",
		"@commitlint/types": "catalog:lint",
		"@eslint/config-inspector": "catalog:lint",
		"@isentinel/eslint-config": "catalog:lint",
		"@isentinel/hooks": "catalog:lint",
		"@isentinel/tsconfig": "catalog:tsc",
		"@types/bun": "catalog:types",
		"@typescript/native-preview": "catalog:types",
		"@vitest/coverage-v8": "catalog:test",
		"@vitest/eslint-plugin": "catalog:lint",
		"better-typescript-lib": "catalog:tsc",
		"eslint": "catalog:lint",
		"eslint-plugin-erasable-syntax-only": "catalog:lint",
		"eslint-plugin-n": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"eslint_d": "catalog:dev",
		"file-entry-cache": "catalog:dev",
		"generate-jsdoc-example-tests": "catalog:test",
		"get-tsconfig": "catalog:dev",
		"jiti": "catalog:script",
		"madge": "catalog:dev",
		"monocart-coverage-reports": "catalog:test",
		"oxc-minify": "catalog:dev",
		"pncat": "catalog:dev",
		"publint": "catalog:lint",
		"std-env": "catalog:script",
		"tsx": "catalog:script",
		"typedoc": "catalog:build",
		"typedoc-plugin-replace-text": "catalog:build",
		"typescript": "catalog:tsc",
		"unplugin-unused": "catalog:build",
		"vite-plus": "catalog:build",
		"vitest": "catalog:test"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"engines": {
		"bun": ">=1.3.0"
	}
}
