amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

// Workaround: hk util commands fail on Windows via cmd.exe, bash -c fixes it
local bash: String = "bash -c"

// Agent detection: prints "true" if running inside an AI agent (Claude, Cursor, etc.)
local isAgent: String = #"exec("bun scripts/is-agent.ts") == "true""#

local preCommitBranchGuard = new Step {
    check = "hk util no-commit-to-branch --branch main"
    shell = bash
}

local sharedGuards = new Mapping<String, Step> {
    ["check-merge-conflict"] = (Builtins.check_merge_conflict) { shell = bash }
    ["detect-private-key"] = (Builtins.detect_private_key) { shell = bash }
    ["check-added-large-files"] = (Builtins.check_added_large_files) {
        shell = bash
        exclude = List("pnpm-lock.yaml", "packages/*/vendor/**")
    }
}

// Base checker steps — used directly by `hk check`, conditioned for hooks
local genExampleTests = new Step {
    check = "pnpm gen:example-tests"
    shell = bash
    exclusive = true
}

local lint = new Step {
	check = "pnpm lint:affected"
	fix = "pnpm lint:affected --fix"
	shell = bash
}

local typecheck = new Step {
    glob = List("*.ts", "*.tsx")
    check = "pnpm typecheck:affected"
    shell = bash
	stomp = true
}

local test = new Step {
    glob = List("*.ts", "*.tsx")
    check = "pnpm test:affected"
    shell = bash
    exclusive = true
}

// CI variant of `test` — runs with coverage and merges reports. Used only by the
// `check` hook so local hooks (pre-commit/pre-push) stay fast.
local testCi = new Step {
    glob = List("*.ts", "*.tsx")
    check = "pnpm test:ci"
    shell = bash
    exclusive = true
}

local build = new Step {
    glob = List("*.ts", "*.tsx")
    check = "pnpm build:affected"
    shell = bash
}

local mutate = new Step {
    glob = List("*.ts", "*.tsx")
    check = "pnpm mutate:changed"
    shell = bash
    exclusive = true
}

// Pre-push variant of `mutate` that scopes against `origin/main`, mirroring
// the CI mutation job. Pre-commit's `mutate` only sees the current slice; a
// survivor exposed by a later slice's tests would slip past without this.
local mutatePush = new Step {
    glob = List("*.ts", "*.tsx")
    check = "MUTATE_BASE_REF=origin/main pnpm mutate:changed"
    shell = bash
    exclusive = true
}

local unused = new Step {
    glob = List("*.ts", "*.tsx", "package.json", "pnpm-workspace.yaml")
    check = "pnpm lint:unused"
    shell = bash
    exclusive = true
}

hooks {
    ["pre-commit"] {
		fix = true
        stash = "none"
        steps {
            ...sharedGuards
            ["no-commit-to-branch"] = preCommitBranchGuard
            ["typecheck"] = (typecheck)
            ["build"] = (build) { condition = isAgent }
			["lint"] = (lint)
            ["gen-example-tests"] = (genExampleTests) { condition = isAgent }
            ["test"] = (test) { condition = isAgent }
            ["mutate"] = (mutate) { condition = isAgent }
        }
    }
    ["pre-push"] {
        steps {
            ["typecheck"] = typecheck
            ["build"] = build
            ["unused"] = unused
			["lint"] = lint
            ["gen-example-tests"] = genExampleTests
            ["test"] = test
            ["mutate"] = (mutatePush) { condition = isAgent }
        }
    }
    ["commit-msg"] {
        steps {
            ["commitlint"] {
                check = "pnpm commitlint --edit {{commit_msg_file}}"
                shell = bash
            }
        }
    }
    ["post-merge"] {
        steps {
            ["install-deps"] {
                glob = List("pnpm-lock.yaml")
                check = "pnpm install"
                shell = bash
            }
            ["mise-install"] {
                glob = List("mise.toml")
                check = "mise install"
                shell = bash
            }
        }
    }
    ["check"] {
        steps {
            ...sharedGuards
            ["typecheck"] = typecheck
            ["build"] = build
            ["unused"] = unused
			["lint"] = lint
            ["gen-example-tests"] = genExampleTests
            ["test"] = testCi
        }
    }
}
