{
	"name": "@bedrock/website",
	"version": "0.0.1",
	"private": true,
	"description": "Bedrock documentation website",
	"keywords": [
		"documentation",
		"website"
	],
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"scripts": {
		"docs:build": "typedoc && vitepress build",
		"docs:dev": "concurrently -k -n typedoc,vitepress -c magenta,cyan \"typedoc --watch\" \"vitepress dev\"",
		"lint": "eslint --cache .",
		"preview": "vitepress preview"
	},
	"devDependencies": {
		"concurrently": "catalog:dev",
		"typedoc": "catalog:build",
		"typedoc-plugin-markdown": "catalog:build",
		"typedoc-plugin-replace-text": "catalog:build",
		"vitepress": "catalog:docs",
		"vitepress-plugin-tabs": "catalog:docs"
	},
	"engines": {
		"bun": ">=1.0.0"
	}
}
